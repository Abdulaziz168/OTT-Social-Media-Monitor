# Application Settings
APP_NAME=OTT Instagram Monitor
APP_ENV=production
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/instagram_monitor.db
DATABASE_ECHO=False

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Instagram Scraping
INSTAGRAM_MAX_RETRIES=3
INSTAGRAM_RETRY_DELAY=5
INSTAGRAM_TIMEOUT=30000

# Playwright Configuration
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Proxy (optional)
PROXY_URL=

# Scheduler
SCHEDULE_TIME=09:00
SCHEDULE_TIMEZONE=UTC

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Reports
REPORTS_DIR=./reports
SCREENSHOTS_ENABLED=true

# Data
DATA_DIR=./data
LOGS_DIR=./logs
CONFIG_DIR=./config

# Features
ENABLE_TELEGRAM_REPORTS=true
ENABLE_EXCEL_REPORTS=true
ENABLE_DASHBOARD=true
ENABLE_PDF_REPORTS=true
ENABLE_CSV_EXPORT=true
ENABLE_JSON_EXPORT=true
